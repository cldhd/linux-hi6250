// SPDX-License-Identifier: GPL-2.0-only
/*
 * Device tree for Huawei Honor 9 Lite (LLD-L31)
 *
 * Copyright (C) 2026
 */

/dts-v1/;

#include "hi6250.dtsi"
#include "hi6250-huawei-bl-quirks.dtsi"

/ {
	model = "Huawei Honor 9 Lite";
	compatible = "huawei,leland", "hisilicon,hi6250";
	chassis-type = "handset";

	aliases {

	};

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x00400000 0x0 0xDFC00000>,	/* 0x00400000 - 0xDFFFFFFF */
		      <0x1 0x00000000 0x0 0x20000000>;	/* 0x100000000 - 0x11FFFFFFF */
	};

	chosen {
		bootargs = "console=tty0 loglevel=8 root=/dev/mmcblk0p51 rootfstype=ext4 rw rootwait";

		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		stdout-path = "framebuffer0";

		framebuffer0: framebuffer@5d000000 {
			compatible = "simple-framebuffer";
			reg = <0 0x5d000000 0 (1080 * 2160 * 4)>;
			width = <1080>;
			height = <2160>;
			stride = <(1080 * 4)>;
			format = "a8r8g8b8";
			status = "okay";
		};
	};

	reserved-memory {
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		/* Bootloader framebuffer - keep for simplefb */
		framebuffer_reserved: framebuffer@5d000000 {
			reg = <0x0 0x5d000000 0x0 0x8E6000>;
			no-map;
		};

		/*
		 * The Huawei BL reserves 0x34800000-0x348fffff for its own
		 * `pstore-mem` and clobbers it on cold boot, so a ramoops
		 * region at that address never captures console data across
		 * a reset. Move into the gap between isp-boot@34b00000 (ends
		 * 0x34b1ffff) and hifi-data@34f00000 (starts 0x34f00000).
		 * 0x34c00000 has been verified to survive BL hand-off.
		 */
		ramoops@34c00000 {
			compatible = "ramoops";
			reg = <0x0 0x34c00000 0x0 0x100000>;
			record-size = <0x20000>;
			pmsg-size = <0x20000>;
			console-size = <0x80000>;
			ftrace-size = <0x00000>;
		};
	};

};

/* Enable eMMC */
&sdhci0 {
	status = "okay";
};

/* Enable USB2 OTG */
&usb_otg {
	status = "okay";
	/*
	 * Empirical: with the CTRL0 bit-layout fix in place, this is the
	 * value that lets the HS chirp succeed and the gadget enumerate
	 * (also matches downstream linux-huawei-leland DTS). The stock-BL
	 * handoff value 0x05cd06db produces FS-only / EPROTO chaos.
	 */
	hisilicon,eye-diagram-param = <0x059066DB>;
};

